# Ports
UI_PORT=8080
AUTH_PORT=5203
USERAPI_PORT=5204
DBAPI_PORT=5201
POSTGRES_PORT=5432

# Postgres admin user
POSTGRES_USER=mpl
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# Database names created by deploy/postgres/init.sql
AUTH_DB_NAME=mplauthdb
USERAPI_DB_NAME=mpluserdatadb
DBAPI_DB_NAME=b_mplbase

# Shared JWT settings used by auth/dbapi/userapi
JWT_KEY=replace-with-a-long-random-secret
JWT_ISSUER=MplAuth
JWT_AUDIENCE=MplService

# Auth service cert (required by data protection setup)
AUTH_CERT_HOST_PATH=./deploy/certs/auth-cert.pfx
AUTH_CERT_PASSWORD=change-me

# Origin allowed by auth and userapi CORS
APP_ORIGIN=http://localhost:8080

# UI build-time API endpoints
UI_VITE_USE_MOCKS=false
UI_VITE_API_BASE_URL=http://localhost:8080/userapi
UI_VITE_API_AUTH_URL=http://localhost:8080/authapi
UI_REAL_URL=http://localhost:8080

# Optional external spreadsheet generator endpoint used by userapi
SPREADSHEET_API_BASE_URL=http://spreadsheet-gen:5301
